generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum Role {
  ADMIN      // Equipe interna do SaaS
  EMPLOYER   // Dono da empresa/Recrutador
  CANDIDATE  // Candidato
}

enum JobType {
  SELF_SERVICE
  MANAGED
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  SHORTLISTED // Usado internamente no modelo MANAGED antes de ir para o cliente
  INTERVIEW
  REJECTED
  HIRED
}

enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

enum PlacementStatus {
  TRIAL         // Em período de experiência (0-90 dias)
  EFFECTIVE     // Efetivado pela empresa (gera comissão)
  TERMINATED    // Não efetivado / Desligado durante o trial
  CANCELLED     // Cancelado antes de iniciar
}

enum CommissionStatus {
  PENDING       // Comissão gerada, aguardando pagamento
  INVOICED      // Nota fiscal / fatura emitida
  PAID          // Pago pela empresa
  WAIVED        // Dispensada (ex: acordo comercial)
}

// --- MODELS ---

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  password      String?   // Opcional para OAuth
  image         String?
  role          Role      @default(CANDIDATE)
  
  // Relações
  company       Company?  @relation(fields: [companyId], references: [id])
  companyId     String?
  applications  Application[]
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logoUrl     String?  @map("logo_url")
  website     String?
  description String?  @db.Text
  industry    String?
  location    String?
  
  // Subscription management
  plan        PlanType @default(FREE)
  stripeId    String?  @unique @map("stripe_customer_id")

  // Relações
  users       User[]
  jobs        Job[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

model Job {
  id            String    @id @default(uuid())
  title         String
  slug          String    @unique
  description   String    @db.Text
  location      String
  isRemote      Boolean   @default(false) @map("is_remote")
  salaryRange   String?   @map("salary_range") // Ex: "5k - 8k"
  
  requirements    String?   @db.Text
  benefits        String?   @db.Text
  responsibilities String?   @db.Text
  tips            String?   @db.Text
  
  type          JobType   @default(SELF_SERVICE)
  status        JobStatus @default(DRAFT)
  
  // Relações
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId     String    @map("company_id")
  applications  Application[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([companyId])
  @@map("jobs")
}

model Application {
  id           String            @id @default(uuid())
  resumeUrl    String            @map("resume_url")
  coverLetter  String?           @map("cover_letter") @db.Text
  status       ApplicationStatus @default(APPLIED)
  
  // Relações
  job          Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId        String            @map("job_id")
  candidate    User              @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId  String            @map("candidate_id")
  
  shortlist    Shortlist?
  placement    Placement?

  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@unique([jobId, candidateId]) // Impede candidatura duplicada
  @@index([status])
  @@map("applications")
}

model Shortlist {
  id            String      @id @default(uuid())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String      @unique @map("application_id")
  
  adminFeedback String?     @map("admin_feedback") @db.Text
  clientReview  String?     @map("client_review") @db.Text // Feedback do cliente final
  isApproved    Boolean?    @map("is_approved")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("shortlists")
}

model Transaction {
  id            String   @id @default(uuid())
  amount        Int      // Em centavos
  currency      String   @default("BRL")
  status        String   // paid, pending, failed
  provider      String   // stripe, mercado_pago
  providerId    String   @unique @map("provider_transaction_id")
  
  companyId     String   @map("company_id")
  
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("transactions")
}

// --- MÓDULO DE RECRUTAMENTO / CURADORIA ---

model Placement {
  id              String           @id @default(uuid())
  
  // Vínculo com a candidatura original
  application     Application      @relation(fields: [applicationId], references: [id])
  applicationId   String           @unique @map("application_id")
  
  // Dados do contrato
  status          PlacementStatus  @default(TRIAL)
  monthlySalary   Int              @map("monthly_salary")  // Salário em centavos
  startDate       DateTime         @map("start_date")       // Início do trial
  trialEndDate    DateTime         @map("trial_end_date")   // Data limite (start + 90 dias)
  effectiveDate   DateTime?        @map("effective_date")   // Data real da efetivação
  terminationDate DateTime?        @map("termination_date") // Data de desligamento (se houver)
  terminationReason String?        @map("termination_reason") @db.Text
  
  // Observações
  adminNotes      String?          @map("admin_notes") @db.Text
  companyFeedback String?          @map("company_feedback") @db.Text
  
  // Relação com comissão
  commission      Commission?
  
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@map("placements")
}

model Commission {
  id              String           @id @default(uuid())
  
  placement       Placement        @relation(fields: [placementId], references: [id])
  placementId     String           @unique @map("placement_id")
  
  // Valores
  baseSalary      Int              @map("base_salary")       // Salário base (centavos)
  percentage      Float            @default(50)               // Percentual fixo 50%
  amount          Int              // Valor da comissão (centavos) = baseSalary * 50 / 100
  
  // Controle
  status          CommissionStatus @default(PENDING)
  invoiceNumber   String?          @map("invoice_number")
  dueDate         DateTime?        @map("due_date")
  paidAt          DateTime?        @map("paid_at")
  
  // Vínculo com empresa
  companyId       String           @map("company_id")
  
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@index([companyId])
  @@map("commissions")
}
