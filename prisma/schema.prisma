generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  name         String?
  email        String        @unique
  password     String?
  image        String?
  role         Role          @default(CANDIDATE)
  companyId    String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  permissions  String[]      @default([])
  applications Application[]
  company      Company?      @relation(fields: [companyId], references: [id])

  @@map("users")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logoUrl     String?  @map("logo_url")
  website     String?
  description String?
  stripeId    String?  @unique @map("stripe_customer_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  industry    String?
  location    String?
  email       String?
  jobs        Job[]
  users       User[]

  @@map("companies")
}

model Job {
  id               String        @id @default(uuid())
  title            String
  slug             String        @unique
  description      String
  location         String
  isRemote         Boolean       @default(false) @map("is_remote")
  salaryRange      String?       @map("salary_range")
  type             JobType       @default(SELF_SERVICE)
  status           JobStatus     @default(DRAFT)
  companyId        String        @map("company_id")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  benefits         String?
  requirements     String?
  responsibilities String?
  tips             String?
  contractType     String?  @map("contract_type")
  experienceLevel  String?  @map("experience_level")
  applications     Application[]
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([companyId])
  @@map("jobs")
}

model Application {
  id          String            @id @default(uuid())
  resumeUrl   String            @map("resume_url")
  coverLetter String?           @map("cover_letter")
  status      ApplicationStatus @default(APPLIED)
  jobId       String            @map("job_id")
  candidateId String            @map("candidate_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  candidate   User              @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  placement   Placement?
  shortlist   Shortlist?

  @@unique([jobId, candidateId])
  @@index([status])
  @@map("applications")
}

model Shortlist {
  id            String      @id @default(uuid())
  applicationId String      @unique @map("application_id")
  adminFeedback String?     @map("admin_feedback")
  clientReview  String?     @map("client_review")
  isApproved    Boolean?    @map("is_approved")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("shortlists")
}

model Transaction {
  id         String   @id @default(uuid())
  amount     Int
  currency   String   @default("BRL")
  status     String
  provider   String
  providerId String   @unique @map("provider_transaction_id")
  companyId  String   @map("company_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("transactions")
}

model Placement {
  id                String          @id @default(uuid())
  applicationId     String          @unique @map("application_id")
  status            PlacementStatus @default(TRIAL)
  monthlySalary     Int             @map("monthly_salary")
  startDate         DateTime        @map("start_date")
  trialEndDate      DateTime        @map("trial_end_date")
  effectiveDate     DateTime?       @map("effective_date")
  terminationDate   DateTime?       @map("termination_date")
  terminationReason String?         @map("termination_reason")
  adminNotes        String?         @map("admin_notes")
  companyFeedback   String?         @map("company_feedback")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  commission        Commission?
  application       Application     @relation(fields: [applicationId], references: [id])

  @@index([status])
  @@map("placements")
}

model Commission {
  id            String           @id @default(uuid())
  placementId   String           @unique @map("placement_id")
  baseSalary    Int              @map("base_salary")
  percentage    Float            @default(50)
  amount        Int
  status        CommissionStatus @default(PENDING)
  invoiceNumber String?          @map("invoice_number")
  dueDate       DateTime?        @map("due_date")
  paidAt        DateTime?        @map("paid_at")
  companyId     String           @map("company_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  placement     Placement        @relation(fields: [placementId], references: [id])

  @@index([status])
  @@index([companyId])
  @@map("commissions")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String?
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false) @map("is_read")
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

enum Role {
  ADMIN
  EMPLOYER
  CANDIDATE
}

enum JobType {
  SELF_SERVICE
  MANAGED
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  SHORTLISTED
  INTERVIEW
  REJECTED
  HIRED
}

enum PlacementStatus {
  TRIAL
  EFFECTIVE
  TERMINATED
  CANCELLED
}

enum CommissionStatus {
  PENDING
  INVOICED
  PAID
  WAIVED
}
